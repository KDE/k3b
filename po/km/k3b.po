#: projects/base_k3badvanceddataimagesettings.ui:24
#, kde-format
msgid "Add Rock Ridge extensions to the file system"
msgstr "бһ”бһ“бҹ’бһҗбҹӮбһҳвҖӢбһ•бҹ’бһ“бҹӮбһҖвҖӢбһ”бһ“бҹ’бһҗбҹӮбһҳвҖӢвҖӢ Rock Ridge бһ‘бҹ…вҖӢбһҖбһ¶бһ“бҹӢвҖӢбһ”бҹ’бһҡбһ–бҹҗбһ“бҹ’бһ’вҖӢбһҜбһҖбһҹбһ¶бһҡвҖӢ"

#. i18n: ectx: property (whatsThis), widget (QCheckBox, m_checkRockRidge)
#: projects/base_k3badvanceddataimagesettings.ui:30
#, fuzzy, kde-format
#| msgid ""
#| "<p>If this option is checked, K3b will generate the System Use Sharing "
#| "Protocol records (SUSP) specified by the Rock Ridge Interchange Protocol "
#| "(IEEE-P1282).\n"
#| "<p>Rock Ridge extends the ISO-9660 filesystem by features equal to the "
#| "UNIX filesystems (permissions, symbolic links, very long filenames, ...). "
#| "It uses ISO-8859 or UTF-16 based characters and allows 255 octets.\n"
#| "<p>Rock Ridge extensions are located at the end of each ISO-9660 "
#| "directory record. This makes the Rock Ridge tree closely coupled to the "
#| "ISO-9660 tree.\n"
#| "<p><b>It is highly recommended to use Rock Ridge extensions on every data "
#| "CD or DVD.</b>"
msgid ""
"<p>If this option is checked, K3b will generate the System Use Sharing "
"Protocol records (SUSP) specified by the Rock Ridge Interchange Protocol "
"(IEEE-P1282).\n"
"<p>Rock Ridge extends the ISO 9660 filesystem by features equal to the UNIX "
"filesystems (permissions, symbolic links, very long filenames, ...). It uses "
"ISO-8859 or UTF-16 based characters and allows 255 octets.\n"
"<p>Rock Ridge extensions are located at the end of each ISO 9660 directory "
"record. This makes the Rock Ridge tree closely coupled to the ISO 9660 "
"tree.\n"
"<p><b>It is highly recommended to use Rock Ridge extensions on every data CD "
"or DVD.</b>"
msgstr ""
"<p>бһ”бһҫвҖӢбһӮбһјбһҹвҖӢбһ’бһёбһҖвҖӢбһҮбһҳбҹ’бһҡбһҫбһҹвҖӢбһ“бҹҒбҹҮ K3b бһ“бһ№бһ„вҖӢбһ”бһ„бҹ’бһҖбһҫбһҸвҖӢбһ”бҹ’бһҡбһ–бҹҗбһ“бҹ’бһ’вҖӢ бһ”бҹ’бһҡбһҫвҖӢбһҖбһ¶бһҡвҖӢбһ…бҹӮбһҖбһ…бһ¶бһҷвҖӢбһҖбҹҶбһҺбһҸбҹӢвҖӢбһҸбҹ’бһҡбһ¶вҖӢбһ–бһ·бһ’бһёбһҖбһ¶бһҡвҖӢ (SUSP) бһҠбҹӮбһӣвҖӢбһ”бһ¶бһ“вҖӢбһ”бһүбҹ’бһҮбһ¶бһҖбҹӢвҖӢ"
"бһҠбҹ„бһҷвҖӢбһ–бһ·бһ’бһёбһҖбһ¶бһҡвҖӢбһ•бҹ’бһӣбһ¶бһҹбҹӢвҖӢбһ”бҹ’бһҠбһјбһҡвҖӢвҖӢ Rock Ridge (IEEE-P1282) бҹ”\n"
"<p>Rock Ridge бһ–бһ„бҹ’бһҡбһёбһҖвҖӢбһ”бҹ’бһҡбһ–бҹҗбһ“бҹ’бһ’вҖӢбһҜбһҖбһҹбһ¶бһҡвҖӢвҖӢ ISO-9660 вҖӢбһҸбһ¶бһҳвҖӢбһӣбһҖбҹ’бһҒбһҺвҖӢбһ–бһ·бһҹбҹҒбһҹвҖӢбһҠбҹӮбһӣвҖӢбһҹбҹ’бһҳбһҫбһ“бһ№бһ„вҖӢвҖӢбһ”бҹ’бһҡбһ–бҹҗбһ“бҹ’бһ’вҖӢбһҜбһҖбһҹбһ¶бһҡвҖӢ UNIX  "
"(бһҹбһ·бһ‘бҹ’бһ’вҖӢ бһҸбҹҶбһҺвҖӢбһ“бһ·бһҳбһ·бһҸбҹ’бһҸвҖӢбһҹбһүбҹ’бһүбһ¶вҖӢ бһҲбҹ’бһҳбҹ„бҹҮвҖӢбһҜбһҖбһҹбһ¶бһҡвҖӢбһңбҹӮбһ„вҖӢ ...) бҹ” бһңбһ¶вҖӢбһ”бҹ’бһҡбһҫвҖӢбһҸбһҪвҖӢбһўбһҖбҹ’бһҹбһҡвҖӢбһҠбҹӮбһӣвҖӢбһ•бҹ’бһўбҹӮбһҖвҖӢбһӣбһҫвҖӢвҖӢ ISO-8859 бһ¬ UTF-16  бһ“бһ·бһ„вҖӢ"
"бһўбһ“бһ»бһүбҹ’бһүбһ¶бһҸвҖӢбһІбҹ’бһҷвҖӢбһҳбһ¶бһ“вҖӢбһҸбҹ’бһҡбһ№бһҳвҖӢ бҹўвҖӢбҹҘвҖӢбҹҘ octets бҹ”\n"
"<p>бһ•бҹ’бһ“бҹӮбһҖвҖӢбһ”бһ“бҹ’бһҗбҹӮбһҳвҖӢвҖӢ Rock Ridge бһҹбҹ’бһҗбһ·бһҸвҖӢбһ“бҹ…вҖӢбһҒбһ¶бһ„вҖӢбһ…бһ»бһ„вҖӢбһ“бҹғвҖӢбһҖбҹҶбһҺбһҸбҹӢвҖӢбһҸбҹ’бһҡбһ¶вҖӢбһҗбһҸвҖӢ  ISO-9660 вҖӢбһ“бһёбһҳбһҪбһҷбҹ— бҹ”  бһңбһ¶вҖӢбһ’бҹ’бһңбһҫвҖӢбһІбҹ’бһҷвҖӢбһҳбҹӮбһҖвҖӢбһ’бһ¶бһ„вҖӢ "
"Rock Ridge бһ”бҹ’бһҡбһ‘бһ¶бһҖбҹӢвҖӢбһӮбҹ’бһ“бһ¶вҖӢбһҷбҹүбһ¶бһ„вҖӢбһҹбҹ’бһ“бһ·бһ‘бҹ’бһ’вҖӢбһҮбһ¶вҖӢбһҳбһҪбһҷвҖӢбһ“бһ№бһ„вҖӢбһҳбҹӮбһҖвҖӢбһ’бһ¶бһ„вҖӢ ISO-9660 бҹ”\n"
"<p><b> бһўбҹ’бһ“бһҖвҖӢбһҸбҹ’бһҡбһјбһңвҖӢбһ”бһ¶бһ“вҖӢбһ•бҹ’бһҠбһӣбҹӢвҖӢвҖӢбһўбһ“бһ»бһҹбһ¶бһҹбһ“бҹҚвҖӢбһІбҹ’бһҷвҖӢвҖӢбһ”бҹ’бһҡбһҫвҖӢ бһ•бҹ’бһ“бҹӮбһҖвҖӢбһ”бһ“бҹ’бһҗбҹӮбһҳвҖӢвҖӢ Rock Ridge бһ“бҹ…вҖӢбһӣбһҫвҖӢбһҹбҹҠбһёбһҢбһёвҖӢ бһ¬вҖӢбһҢбһёбһңбһёбһҢбһёвҖӢбһ‘бһ·бһ“бҹ’бһ“бһ“бҹҗбһҷвҖӢбһ‘бһ¶бҹҶбһ„вҖӢбһўбһҹбҹӢвҖӢ бҹ”</"
"b>"

